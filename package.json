{
  "name": "piano-trainer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MIDI-USB piano practice tool for .music.json scores",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "music-json": "file:../music-json-spec",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "music-roll": "file:../music-roll"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/webmidi": "^2.0.10",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.0"
  }
}
